  "components": {
    "schemas": {
      "Tracking": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "tag": {
            "type": "string",
            "enum": [
              "Pending",
              "InfoReceived",
              "InTransit",
              "OutForDelivery",
              "AttemptFail",
              "Delivered",
              "AvailableForPickup",
              "Exception",
              "Expired"
            ]
          },
          "subtag": {
            "type": "string"
          },
          "deliveryType": {
            "type": "string",
            "enum": [
              "pickup_at_store",
              "pickup_at_courier",
              "door_to_door"
            ]
          },
          "active": {
            "type": "boolean"
          },
          "expectedDelivery": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
